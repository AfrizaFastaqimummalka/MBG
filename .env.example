APP_NAME="My Bike Garage"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Jakarta
APP_URL=https://yourdomain.com

APP_LOCALE=id
APP_FALLBACK_LOCALE=id

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ─── Neon PostgreSQL ─────────────────────────────────────────────────────────
# Opsi A: gunakan DATABASE_URL saja
DATABASE_URL=postgresql://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# Opsi B: pisah per variabel (pilih salah satu cara)
DB_CONNECTION=pgsql
DB_HOST=ep-xxx.ap-southeast-1.aws.neon.tech
DB_PORT=5432
DB_DATABASE=neondb
DB_USERNAME=neondb_owner
DB_PASSWORD=your_password
DB_SSLMODE=require

# ─── Cache & Session ─────────────────────────────────────────────────────────
CACHE_STORE=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ─── Queue ───────────────────────────────────────────────────────────────────
QUEUE_CONNECTION=sync

# ─── Mail (untuk password reset) ─────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@mybike.app"
MAIL_FROM_NAME="My Bike Garage"

# ─── Filesystem ──────────────────────────────────────────────────────────────
FILESYSTEM_DISK=local
